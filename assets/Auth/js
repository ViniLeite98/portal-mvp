/**
 * auth.js — Proteção de rotas por role
 * Incluir APÓS supabase.js e ANTES de sidebar.js
 *
 * <script src="assets/js/supabase.js"></script>
 * <script src="assets/js/auth.js" data-role="admin"></script>
 * <script src="assets/sidebar/sidebar.js"></script>
 */

(async function(){
  const scriptEl = document.currentScript;
  const roleExigido = scriptEl?.getAttribute("data-role") || null;

  // 1. Verificar sessão
  const {data:{session}} = await client.auth.getSession();
  if(!session){
    window.location.href = "login.html";
    return;
  }

  // 2. Buscar perfil
  const {data:perfil} = await client.from("perfis")
    .select("role,nome,email")
    .eq("id", session.user.id)
    .single();

  const role  = perfil?.role  || "operadora";
  const nome  = perfil?.nome  || perfil?.email || session.user.email;
  const email = perfil?.email || session.user.email;

  // 3. Verificar permissão da página
  if(roleExigido === "admin" && role !== "admin"){
    window.location.href = "fluxo_caixa.html";
    return;
  }

  // 4. Expor globalmente — sidebar.js vai usar isso
  window.usuarioLogado = {id: session.user.id, role, nome, email};

  // 5. Renderizar sidebar quando DOM estiver pronto
  // sidebar.js carrega depois deste script, então usamos DOMContentLoaded
  const render = () => {
    if(typeof window.renderSidebar === "function") window.renderSidebar();
  };

  if(document.readyState === "loading"){
    document.addEventListener("DOMContentLoaded", render);
  } else {
    render();
  }

})();

async function logout(){
  try{ await client.auth.signOut(); }catch(e){}
  Object.keys(localStorage).forEach(k=>{ if(k.startsWith("sb-")) localStorage.removeItem(k); });
  window.location.href = "login.html";
}
